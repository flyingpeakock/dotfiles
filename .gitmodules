[submodule ".config/tmux/plugins/tmux-sessionist"]
	path = .config/tmux/plugins/tmux-sessionist
	url = https://github.com/tmux-plugins/tmux-sessionist.git
[submodule ".config/vim/plugged/rust.vim"]
	path = .config/vim/plugged/rust.vim
	url = https://github.com/rust-lang/rust.vim
[submodule ".config/vim/plugged/animate.vim"]
	path = .config/vim/plugged/animate.vim
	url = https://github.com/camspiers/animate.vim
[submodule ".config/vim/plugged/nerdtree"]
	path = .config/vim/plugged/nerdtree
	url = https://github.com/preservim/nerdtree
[submodule ".config/vim/plugged/vim-fugitive"]
	path = .config/vim/plugged/vim-fugitive
	url = https://github.com/tpope/vim-fugitive
[submodule ".config/vim/plugged/lens.vim"]
	path = .config/vim/plugged/lens.vim
	url = https://github.com/camspiers/lens.vim
