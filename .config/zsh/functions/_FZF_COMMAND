function _FZF_COMMAND {
    if [ -v TMUX ] && [ ! -z "$_FZF_POPOUT"]; then
        fzf-tmux -p -w 95% -h 50% --preview-window right:60% $@
    else
        fzf --height=60% --layout=reverse --preview-window down:60% $@
    fi
}

echo '' | fzf-tmux -p -1 &> /dev/null
if [ "$?" -gt 0 ]; then
    _FZF_POPOUT=
else
    _FZF_POPOUT="-p"
fi
_FZF_COMMAND
