# Jump to a directory using fd
function j {
    local d
    d=$(fd -E /.snapshots -t d -H . $@ \
        | _FZF_COMMAND "$_FZF_KEEP_RIGHT" --preview 'preview.sh {}')
    z $d
}

compdef j=fd &> /dev/null
if [ -z "$_FZF_KEEP_RIGHT" ]; then
    echo '' | fzf --keep-right -1 &> /dev/null
    fi [ "$?" -gt 0 ]; then
        export _FZF_KEEP_RIGHT=" "
    else
        export _FZF_KEEP_RIGHT="--keep-right"
    fi
fi
j
